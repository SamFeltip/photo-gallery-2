---
import { init, type AlbumResponseDto } from "@immich/sdk";
import { getAlbumPeople } from "../pages/api/people/[id]";

interface Props {
  album: AlbumResponseDto;
}

const { album } = Astro.props;
const PERSON_API_KEY = import.meta.env.PERSON_API_KEY;

const IMMICH_BASE_URL = import.meta.env.IMMICH_BASE_URL;
const API_KEY = import.meta.env.API_KEY;

init({
  baseUrl: `${IMMICH_BASE_URL}/api`,
  apiKey: API_KEY,
});

const albumPeople = await getAlbumPeople(album.id);
const people = Array.from(albumPeople.entries()); // [string, PersonResponseDto][]
---

<ul>
  {
    people
      .filter(([personId, person]) => person.name !== "")
      .map(([personId, person]) => (
        <li>
          <img
            class="loadIn avatar"
            height="100px"
            src={`${IMMICH_BASE_URL}/api/people/${personId}/thumbnail?apiKey=${PERSON_API_KEY}`}
          />
        </li>
      ))
  }
</ul>
<style>
  @keyframes bulge {
    0% {
      scale: 1;
    }
    50% {
      scale: 1.12;
    }
    100% {
      scale: 1.1;
    }
  }

  @keyframes bulge-reverse {
    0% {
      scale: 1.1;
    }
    50% {
      scale: 0.98;
    }
    100% {
      scale: 1;
    }
  }

  img.avatar {
    border-radius: 100px;
    max-width: inherit;
    transition: transform 0.1s ease;
    &:hover {
      transform: translateY(-5px);
      cursor: pointer;
    }
    &.active {
      scale: 1.1;
    }
    &.animate {
      animation: bulge 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      &.reverse {
        animation: bulge-reverse 0.35s cubic-bezier(0.34, 1.56, 0.64, 1)
          forwards;
      }
    }
  }

  ul {
    padding: 1rem;
    display: flex;
    gap: 1rem;
    max-width: 100%;
    overflow: scroll;
    margin-bottom: 1rem;
  }
</style>

<script>
  const imgs = document.querySelectorAll("img.avatar");

  imgs.forEach((img) => {
    img.addEventListener("click", () => {
      const willActivate = !img.classList.contains("active");

      img.classList.remove("animate", "reverse");
      void (img as HTMLElement).offsetWidth; // force reflow so the animation restarts on repeat clicks

      img.classList.add("animate");
      if (!willActivate) img.classList.add("reverse");

      img.classList.toggle("active", willActivate);
    });

    img.addEventListener("animationend", () => {
      img.classList.remove("animate", "reverse");
    });
  });
</script>
