---
import { Font, Image } from "astro:assets";
import { thumbHashToDataURL } from "thumbhash";

import "@fancyapps/ui/dist/fancybox/fancybox.css";
import { getShareLinks } from "../lib/immichHelpers";

const IMMICH_BASE_URL = import.meta.env.IMMICH_BASE_URL;
const API_KEY = import.meta.env.API_KEY;

export async function getStaticPaths() {
  const IMMICH_BASE_URL = import.meta.env.IMMICH_BASE_URL;
  const API_KEY = import.meta.env.API_KEY;

  const permanentLinks = await getShareLinks(IMMICH_BASE_URL, API_KEY);

  return permanentLinks.map((link) => ({
    params: { id: link.album.id },
  }));
}

const { id } = Astro.params;

// --- helper accessors (adjust here if your API shape differs) ---
function getRating(asset: any) {
  // ACCESSOR SPOT 1: change if rating isn't at asset.exifInfo.rating
  return asset?.exifInfo?.rating ?? 0;
}

function getDescription(asset: any) {
  return asset?.exifInfo?.description || asset?.originalFileName || "";
}

// --- fetch all stacks once, build assetId -> stackId lookup ---
// Album/asset responses don't reliably include stack membership, so we
// hit /api/stacks separately and index it ourselves.
async function getAssetIdToStackIdMap() {
  const res = await fetch(`${IMMICH_BASE_URL}/api/stacks`, {
    headers: {
      "x-api-key": API_KEY,
      Accept: "application/json",
    },
  });

  if (!res.ok) {
    throw new Error(`Failed to fetch stacks (${res.status} ${res.statusText})`);
  }

  const stacks = await res.json();

  if (!Array.isArray(stacks)) {
    throw new Error("Unexpected response shape for /api/stacks.");
  }

  const map = new Map<string, any>();
  for (const stack of stacks) {
    // Each stack has an id and an array of member assets (including the primary).
    for (const asset of stack.assets ?? []) {
      if (asset?.id) {
        map.set(asset.id, stack);
      }
    }
  }
  return map;
}

async function getAlbum() {
  let album = null;
  if (!IMMICH_BASE_URL || !API_KEY) {
    throw new Error("Missing IMMICH_BASE_URL or API_KEY in environment.");
  }

  if (!id) {
    throw new Error("No album id provided in route.");
  }

  const res = await fetch(`${IMMICH_BASE_URL}/api/albums/${id}`, {
    headers: {
      "x-api-key": API_KEY,
      Accept: "application/json",
    },
  });

  if (!res.ok) {
    throw new Error(`Failed to fetch album (${res.status} ${res.statusText})`);
  } else {
    album = await res.json();
  }

  return album;
}

async function getDisplayAssets(album: any) {
  const rawAssets = album?.assets ?? [];

  // One extra request to resolve stack membership for all assets at once.
  const assetIdToStackId = await getAssetIdToStackIdMap();

  // --- collapse stacks to their highest-rated asset ---
  const bestByGroup = new Map();

  for (const asset of rawAssets) {
    const stack = assetIdToStackId.get(asset.id) ?? null;
    // Assets not in a stack are their own group, keyed by their own id.

    if (stack != null) {
      if (stack.primaryAssetId === asset.id) {
        bestByGroup.set(stack?.id, asset);
      }
      continue;
    }

    // asset is not in a stack. check it isn't already present and add.
    const existing = bestByGroup.get(asset.id);
    if (!existing || getRating(asset) > getRating(existing)) {
      bestByGroup.set(asset.id, asset);
    }
  }

  // --- filter out 1-star assets ---
  return Array.from(bestByGroup.values()).filter((asset) =>
    [null, 0, 3, 4, 5].includes(getRating(asset)),
  );
}

async function getShareKey() {
  let links = null;

  if (!id) {
    throw new Error("No album id provided in route.");
  }

  const res = await fetch(`${IMMICH_BASE_URL}/api/shared-links`, {
    headers: {
      "x-api-key": API_KEY,
      Accept: "application/json",
    },
  });

  if (!res.ok) {
    throw new Error(`Failed to fetch album (${res.status} ${res.statusText})`);
  } else {
    links = await res.json();
  }

  if (!Array.isArray(links)) {
    throw new Error("Unexpected response shape for shared links.");
  }

  const link = links.find(
    (link) =>
      link.album.id === id &&
      (link.expiresAt == null || new Date(link.expiresAt) > new Date()),
  );

  if (!link) {
    throw new Error(`No shared link found for album id ${id}`);
  }

  return link.key;
}

let errorMessage = null;

let shareKey = null;
try {
  shareKey = await getShareKey();
} catch (err) {
  if (err instanceof Error) {
    errorMessage = `Error fetching shared link: ${err.message}`;
  }
}

let album = null;
let displayAssets = [];

if (errorMessage === null) {
  try {
    album = await getAlbum();
    displayAssets = await getDisplayAssets(album);
  } catch (err) {
    if (err instanceof Error) {
      errorMessage = `Error fetching album: ${err.message}`;
    }
  }
}

// cache the result so we don't hammer the API on every request
if (!import.meta.env.DEV) {
  // 3600 seconds = 1 hour
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=3600, must-revalidate",
  );
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Photo Gallery • {album.albumName}</title>
    <meta name="description" content={album.description} />
    <meta property="og:title" content={album.albumName} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${IMMICH_BASE_URL}/api/assets/${album.albumThumbnailAssetId}/thumbnail?key=${shareKey}&size=preview`}/>
    <meta property="og:image:alt" content={album.description} />

    <meta property="og:description" content={album.description} />
    <Font cssVariable="--font-unbounded" />
  </head>
  <body>
    <main>
      {
        errorMessage ? (
          <p>{errorMessage}</p>
        ) : (
          <h1><a href="/">{album.albumName}</a></h1>
          <section class="justified-gallery" id="photoswipe">
            {Object.values(displayAssets)
              .toSorted((a, b) => a.fileCreatedAt - b.fileCreatedAt)
              .map((asset) => {
                console.debug({ asset });
                const height = Number(asset?.exifInfo?.exifImageHeight) ?? 1;
                const width = Number(asset?.exifInfo?.exifImageWidth) ?? 1;

                const orientation = [8, 6].includes(
                  Number(asset?.exifInfo?.orientation),
                )
                  ? "portrait"
                  : "landscape";

                const imgHeight = orientation === "portrait" ? width : height;
                const imgWidth = orientation === "portrait" ? height : width;

                // helper: base64 string -> Uint8Array (Node has atob globally in Astro's runtime)
                function toDataUrl(base64Hash: string) {
                  const binary = atob(base64Hash);
                  const bytes = new Uint8Array(binary.length);
                  for (let i = 0; i < binary.length; i++) {
                    bytes[i] = binary.charCodeAt(i);
                  }
                  return thumbHashToDataURL(bytes);
                }

                const placeholder = toDataUrl(asset.thumbhash);

                return (
                  <a
                    style={`--width: ${imgWidth}; --height: ${imgHeight}; --placeholder-url: url(${placeholder});`}
                    href={`${IMMICH_BASE_URL}/api/assets/${asset.id}/thumbnail?key=${shareKey}&size=fullsize`}
                    target="_blank"
                    data-fancybox="gallery"
                    class="thumbhash-img"
                  >
                    <Image
                      id={asset.id}
                      width={imgWidth}
                      height={imgHeight}
                      src={`${IMMICH_BASE_URL}/api/assets/${asset.id}/thumbnail?key=${shareKey}&size=preview`}
                      alt={getDescription(asset)}
                    />
                  </a>
                );
              })}
          </section>
        )
      }
    </main>

    <script>
      import { Fancybox } from "@fancyapps/ui/dist/fancybox/";

      Fancybox.bind("[data-fancybox]", {
        theme: "auto",
        mainStyle: {
          "--f-button-width": "44px",
          "--f-button-height": "44px",
          "--f-button-border-radius": "50%",
          "--f-toolbar-padding": "16px",
        },
        Carousel: {
          Arrows: false,
          Toolbar: {
            display: {
              left: [],
              middle: [],
              right: ["close"],
            },
          },
          transition: "slide",
        },
      });
    </script>

    <style is:global>
      /* Minimal CSS reset */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html,
      body {
        height: 100%;
      }
      img {
        display: block;
        max-width: 100%;
      }
      ul {
        list-style: none;
      }
      h1 {
        font-family: var(--font-unbounded);
        margin-bottom: 1rem;
         a {
            text-decoration: none; /* no underline */
            color: inherit; /* inherit color from parent */
         }
      }

    </style>

    <style>
      main {
        --padding: max(2.5vw, 12px);
        padding: var(--padding);
      }

      .justified-gallery {
        --space: clamp(12px, 1.25vw, 6px);
        --min-height: clamp(200px, 20vw, 400px);

        display: flex;
        flex-wrap: wrap;
        gap: var(--space);

        a {
          flex-grow: calc(var(--width) * (100000 / var(--height)));
          flex-basis: calc(var(--min-height) * (var(--width) / var(--height)));
          aspect-ratio: var(--width) / var(--height);
          overflow: hidden;
          opacity: 1;
          transition: all 0.05s ease-in-out;
        }

        a img {
          display: block;
          object-fit: cover;
          height: 100%;
          width: 100%;
        }

        a:focus-visible {
          outline: 3px solid var(--outline);
          outline-offset: 2px;
          transform: scale(1.05);
          z-index: 1;
          border-radius: 2px;
          box-shadow: 0 2px 4px 2px rgba(0, 0, 0, 0.1);
        }

        a.hidden {
          transition: opacity 0.4s ease-in-out;
          opacity: 0;
        }

        &::after {
          content: " ";
          flex-grow: 1000000000;
        }
      }
    </style>
    <style>
      .thumbhash-img {
        background-image: var(--placeholder-url);
        background-size: cover;
        background-repeat: no-repeat;

        img {
          opacity: 0;
          transform: scale(1.03);
          transition:
            opacity 0.2s ease-in-out,
            transform 0.3s ease-in-out;
        }
      }

      .thumbhash-img {
        img.loaded {
          opacity: 1;
          transform: scale(1);
        }
      }
    </style>
    <script>
      function markLoaded(img: HTMLImageElement) {
        img.classList.add("loaded");
      }

      document
        .querySelectorAll(".thumbhash-img > img")
        .forEach((img: Element) => {
          const htmlImg = img as HTMLImageElement;
          if (htmlImg.complete && htmlImg.naturalWidth > 0) {
            // already loaded from cache — no fade needed, just show it
            markLoaded(htmlImg);
          } else {
            htmlImg.addEventListener("load", () => markLoaded(htmlImg), {
              once: true,
            });
          }
        });
    </script>
  </body>
</html>
